# MongoDB 连接字符串 (必需)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/duoyu?retryWrites=true&w=majority

# OpenAI API Key (用于LLM分析，可选)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 火山引擎 TTS API Key (用于语音合成，可选)
VOLCENGINE_ACCESS_KEY=your_access_key
VOLCENGINE_SECRET_KEY=your_secret_key

# 前端API基础URL (开发环境使用，生产环境不需要)
VITE_API_BASE_URL=/api